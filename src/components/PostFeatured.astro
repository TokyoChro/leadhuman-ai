---
/**
 * Option B: Featured/Spotlight Layout
 * Big hero image with text overlay at the bottom.
 * High visual impact. Image ratio doesn't matter because it fills the frame.
 */
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  href: string;
  category?: "build" | "lead";
  readingTime?: number;
  image?: ImageMetadata;
}

const { title, description, pubDate, href, category, readingTime, image } = Astro.props;
const formattedDate = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});

const categoryLabel = category === "build" ? "BUILD WITH AI" : category === "lead" ? "LEAD HUMANLY" : null;
const categoryColor = category === "build" ? "bg-indigo-accent" : "bg-ivy";
---

<a href={href} class="block group animate-on-scroll">
  <article class="relative rounded-xl overflow-hidden shadow-sm transition-all duration-200 hover:shadow-xl hover:-translate-y-1">
    {image && (
      <Image
        src={image}
        alt={title}
        width={896}
        format="webp"
        quality={80}
        class="w-full aspect-[4/3] object-cover transition-transform duration-500 group-hover:scale-[1.02]"
        loading="lazy"
      />
    )}
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 p-6 text-white">
      <div class="flex items-center gap-2 mb-2">
        {categoryLabel && (
          <span class={`text-xs font-semibold px-2.5 py-0.5 rounded-full text-white/90 ${categoryColor}`}>{categoryLabel}</span>
        )}
        <time class="text-sm text-white/70" datetime={pubDate.toISOString()}>{formattedDate}</time>
        {readingTime && (
          <span class="text-sm text-white/70">&middot; {readingTime} min read</span>
        )}
      </div>
      <h3 class="text-2xl font-bold leading-snug">{title}</h3>
      <p class="text-base text-white/80 mt-2 leading-relaxed line-clamp-2">{description}</p>
    </div>
  </article>
</a>
