---
import PostCard from "./PostCard.astro";
import { getCollection } from "astro:content";
import type { ImageMetadata } from "astro";

interface Props {
  currentId: string;
  currentTags: string[];
  collection: "build" | "lead";
}

const { currentId, currentTags, collection } = Astro.props;

const allPosts = await getCollection(collection, ({ data }) => !data.draft);

const related = allPosts
  .filter((post) => post.id !== currentId)
  .map((post) => {
    const overlap = post.data.tags.filter((tag) => currentTags.includes(tag)).length;
    return { post, overlap };
  })
  .sort((a, b) => b.overlap - a.overlap)
  .slice(0, 3)
  .map(({ post }) => post);

function getReadingTime(body: string | undefined) {
  if (!body) return 0;
  return Math.ceil(body.split(/\s+/).length / 200);
}
---

{related.length > 0 && (
  <section class="mt-12 pt-8 border-t border-stone-300">
    <h2 class="text-xl font-bold text-heading mb-6">You might also like</h2>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {related.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          href={`/${collection}/${post.id}/`}
          category={collection}
          readingTime={getReadingTime(post.body)}
          image={post.data.image as ImageMetadata | undefined}
        />
      ))}
    </div>
  </section>
)}
