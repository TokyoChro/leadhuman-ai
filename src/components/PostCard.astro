---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  href: string;
}

const { title, description, pubDate, href } = Astro.props;
const formattedDate = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<a href={href} class="block group">
  <article class="bg-surface border border-surface rounded-lg p-5 shadow-sm hover:shadow-md hover:border-muted/40 transition-all">
    <time class="text-xs text-muted">{formattedDate}</time>
    <h3 class="text-lg font-semibold mt-1 text-heading group-hover:text-ivy transition-colors">{title}</h3>
    <p class="text-sm text-body mt-2 line-clamp-2">{description}</p>
  </article>
</a>
