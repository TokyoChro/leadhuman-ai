---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  href: string;
  category?: "build" | "lead";
  readingTime?: number;
  image?: ImageMetadata;
  lang?: "en" | "ja";
}

const { title, description, pubDate, href, category, readingTime, image, lang = "en" } = Astro.props;
const dateLocale = lang === "ja" ? "ja-JP" : "en-US";
const formattedDate = pubDate.toLocaleDateString(dateLocale, {
  year: "numeric",
  month: lang === "ja" ? "long" : "short",
  day: "numeric",
});

const categoryLabel = category === "build" ? "BUILD WITH AI" : category === "lead" ? "LEAD HUMANLY" : null;
const categoryColor = category === "build" ? "bg-indigo-accent" : "bg-ivy";
const borderColor = category === "build" ? "border-sky-700" : "border-emerald-800";
---

<a href={href} class="block group animate-on-scroll h-full">
  <article class={`h-full flex flex-col bg-surface border border-card-border border-l-4 ${borderColor} rounded-lg overflow-hidden shadow-sm transition-all duration-200 hover:shadow-lg hover:-translate-y-1`}>
    {image && (
      <div class="aspect-square rounded-t-lg bg-surface flex items-center justify-center">
        <Image
          src={image}
          alt={title}
          width={640}
          format="webp"
          quality={80}
          class="w-full h-full object-contain"
          loading="lazy"
        />
      </div>
    )}
    <div class="p-6 flex-1 flex flex-col">
      <div class="flex items-center gap-2 mb-3">
        {categoryLabel && (
          <span class={`text-sm font-semibold px-3 py-1 rounded-full text-white ${categoryColor}`}>{categoryLabel}</span>
        )}
        <time class="text-sm text-muted" datetime={pubDate.toISOString()}>{formattedDate}</time>
        {readingTime && (
          <span class="text-sm text-muted">&middot; {readingTime}{lang === "ja" ? "分で読める" : " min read"}</span>
        )}
      </div>
      <h3 class="text-2xl font-bold text-heading group-hover:text-ivy transition-colors">{title}</h3>
      <p class="text-base text-stone-600 mt-3 leading-relaxed line-clamp-5 flex-1">{description}</p>
    </div>
  </article>
</a>
