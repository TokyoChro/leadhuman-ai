---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  href: string;
  category?: "build" | "lead";
  readingTime?: number;
  image?: string;
  imagePosition?: string;
}

const { title, description, pubDate, href, category, readingTime, image, imagePosition } = Astro.props;
const formattedDate = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});

const categoryLabel = category === "build" ? "BUILD WITH AI" : category === "lead" ? "LEAD HUMANLY" : null;
const categoryColor = category === "build" ? "bg-indigo-accent" : "bg-ivy";
const borderColor = category === "build" ? "border-sky-700" : "border-emerald-800";
---

<a href={href} class="block group">
  <article class={`bg-surface border border-card-border border-l-4 ${borderColor} rounded-lg overflow-hidden shadow-sm transition-all duration-200 hover:shadow-lg hover:-translate-y-1`}>
    {image && (
      <img
        src={image}
        alt={title}
        class="w-full h-52 object-cover"
        style={`object-position: ${imagePosition || 'center'}`}
        width="400"
        height="200"
        loading="lazy"
      />
    )}
    <div class="p-5">
      <div class="flex items-center gap-2 mb-3">
        {categoryLabel && (
          <span class={`text-xs font-semibold px-2 py-0.5 rounded-full text-white ${categoryColor}`}>{categoryLabel}</span>
        )}
        <time class="text-xs text-muted">{formattedDate}</time>
        {readingTime && (
          <span class="text-xs text-muted">&middot; {readingTime} min read</span>
        )}
      </div>
      <h3 class="text-xl font-bold text-heading group-hover:text-ivy transition-colors">{title}</h3>
      <p class="text-sm text-stone-600 mt-2 leading-relaxed line-clamp-3">{description}</p>
    </div>
  </article>
</a>
