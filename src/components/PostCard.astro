---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  href: string;
}

const { title, description, pubDate, href } = Astro.props;
const formattedDate = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<a href={href} class="block group">
  <article class="border border-gray-800 rounded-lg p-5 hover:border-gray-600 transition-colors">
    <time class="text-xs text-gray-500">{formattedDate}</time>
    <h3 class="text-lg font-semibold mt-1 group-hover:text-white transition-colors">{title}</h3>
    <p class="text-sm text-gray-400 mt-2 line-clamp-2">{description}</p>
  </article>
</a>
