---
interface Props {
  title: string;
  description: string;
  accentColor: "ivy" | "indigo" | "coral";
  href?: string;
}

const { title, description, accentColor, href } = Astro.props;

const borderMap = {
  ivy: "border-emerald-800",
  indigo: "border-sky-700",
  coral: "border-orange-700",
};

const Tag = href ? "a" : "div";
---

<Tag
  href={href}
  class={`block bg-surface border border-card-border border-l-4 ${borderMap[accentColor]} rounded-lg p-5 animate-on-scroll ${href ? "hover:bg-surface-light transition-colors" : ""}`}
>
  <h3 class="text-lg font-bold text-heading mb-2">{title}</h3>
  <p class="text-sm text-body leading-relaxed">{description}</p>
  {href && <span class="text-xs text-ivy font-medium mt-2 inline-block">Read articles &rarr;</span>}
</Tag>
