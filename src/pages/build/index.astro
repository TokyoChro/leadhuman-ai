---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("build", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function getReadingTime(body: string | undefined) {
  if (!body) return 0;
  return Math.ceil(body.split(/\s+/).length / 200);
}
---

<BaseLayout title="Build with AI" description="Posts about building with AI — tools, workflows, and experiments.">
  <h1 class="text-3xl font-bold mb-2 text-heading">Build with AI</h1>
  <p class="text-muted mb-8">Tools, workflows, and experiments in building with AI.</p>

  <div class="grid gap-4 sm:grid-cols-2">
    {posts.map((post) => (
      <PostCard
        title={post.data.title}
        description={post.data.description}
        pubDate={post.data.pubDate}
        href={`/build/${post.id}/`}
        category="build"
        readingTime={getReadingTime(post.body)}
      />
    ))}
  </div>

  {posts.length === 0 && (
    <p class="text-muted italic">No posts yet. Check back soon.</p>
  )}
</BaseLayout>
