---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import YouTubeLite from "../components/YouTubeLite.astro";
import { getCollection } from "astro:content";
import { getReadingTime } from "../utils/reading-time";

const buildPosts = (await getCollection("build", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);

const leadPosts = (await getCollection("lead", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);
---

<BaseLayout title="leadhuman.ai — AI Tutorials & Leadership Insights by Jay Vergara" description="Jay Vergara writes about AI, leadership, and how people actually grow at work. Practical tutorials, cross-cultural insights, and L&D strategy from Tokyo.">
  <!-- Hero -->
  <section class="py-16 md:py-24 hero-text">
    <div class="grid md:grid-cols-[2fr_3fr] items-center gap-10">
      <div>
        <h1 class="text-3xl sm:text-4xl font-bold tracking-tight leading-tight text-heading">
          Lead humanly.<br />Learn constantly.<br />Build with AI.
        </h1>
        <p class="mt-6 text-lg text-muted max-w-xl">
          I'm Jay Vergara, an L&D leader in Tokyo writing about AI, leadership, and how people actually grow at work.
        </p>
      </div>
      <div>
        <YouTubeLite videoId="7q2wFn8qZEU" title="Welcome to leadhuman.ai" />
      </div>
    </div>
  </section>

  <hr class="my-12 divider-gradient" />

  <!-- Latest from Build with AI -->
  <section class="mb-16">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-ivy">Latest from Build with AI</h2>
      <a href="/build/" class="text-sm text-ivy hover:text-ivy-light transition-colors">View all &rarr;</a>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      {buildPosts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          href={`/build/${post.id}/`}
          category="build"
          readingTime={getReadingTime(post.body)}
          image={post.data.image}
        />
      ))}
    </div>
  </section>

  <!-- Latest from Lead Humanly -->
  <section class="mb-16">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-ivy">Latest from Lead Humanly</h2>
      <a href="/lead/" class="text-sm text-ivy hover:text-ivy-light transition-colors">View all &rarr;</a>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      {leadPosts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          href={`/lead/${post.id}/`}
          category="lead"
          readingTime={getReadingTime(post.body)}
          image={post.data.image}
        />
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="text-center py-12">
    <p class="text-sm text-muted mb-4">Follow along</p>
    <div class="flex justify-center gap-4">
      <a
        href="https://linkedin.com/in/vergarajay/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-5 py-3 bg-[#0A66C2] text-white font-semibold rounded-lg hover:bg-[#004182] transition-colors"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        LinkedIn
      </a>
      <a
        href="https://www.youtube.com/@leadhumanai"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-5 py-3 bg-[#FF0000] text-white font-semibold rounded-lg hover:bg-[#cc0000] transition-colors"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        YouTube
      </a>
      <a
        href="https://www.tiktok.com/@leadhuman.ai"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-5 py-3 bg-[#000000] text-white font-semibold rounded-lg hover:bg-[#333333] transition-colors"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
        TikTok
      </a>
    </div>
  </section>
</BaseLayout>
