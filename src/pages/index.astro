---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { getCollection } from "astro:content";

const buildPosts = (await getCollection("build", ({ data }) => !data.draft))
  .map((post) => ({ ...post, category: "build" as const }));

const leadPosts = (await getCollection("lead", ({ data }) => !data.draft))
  .map((post) => ({ ...post, category: "lead" as const }));

const latestPosts = [...buildPosts, ...leadPosts]
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);
---

<BaseLayout title="Home">
  <!-- Hero -->
  <section class="py-16 sm:py-24">
    <h1 class="text-4xl sm:text-5xl font-bold tracking-tight leading-tight text-heading">
      Lead humanly.<br />Learn constantly.<br />Build with AI.
    </h1>
    <p class="mt-6 text-lg text-muted max-w-xl">
      Thoughts on AI, leadership, learning, and building things that matter.
    </p>
  </section>

  <!-- Latest Posts -->
  <section class="mb-16">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-heading">Latest</h2>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      {latestPosts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          href={`/${post.category}/${post.id}/`}
          category={post.category}
        />
      ))}
    </div>
    {latestPosts.length === 0 && (
      <p class="text-muted italic">No posts yet. Check back soon.</p>
    )}
  </section>

  <!-- CTA -->
  <section class="text-center py-12">
    <a
      href="https://linkedin.com/in/vergarajay/"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-block px-6 py-3 bg-coral text-white font-semibold rounded-lg hover:bg-coral-dark transition-colors"
    >
      Connect with me on LinkedIn
    </a>
  </section>
</BaseLayout>
