---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Connect" description="Get in touch with Jay Vergara.">
  <h1 class="text-3xl font-bold mb-6 text-heading">Connect</h1>

  <div class="grid gap-6 sm:grid-cols-2 max-w-2xl">
    <!-- LinkedIn Card -->
    <div class="bg-surface border border-card-border rounded-lg p-6 flex flex-col">
      <div class="flex items-center gap-3 mb-3">
        <svg class="w-8 h-8 text-[#0A66C2]" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        <h2 class="text-lg font-bold text-heading">LinkedIn</h2>
      </div>
      <p class="text-sm text-body mb-6 flex-1">Follow my journey and join the conversation.</p>
      <a
        href="https://linkedin.com/in/vergarajay/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block text-center px-5 py-3 bg-[#0A66C2] text-white font-semibold rounded-lg hover:bg-[#004182] transition-colors"
      >
        Connect on LinkedIn
      </a>
    </div>

    <!-- Peak Potential Card -->
    <div class="bg-surface border border-card-border rounded-lg p-6 flex flex-col">
      <div class="flex items-center gap-3 mb-3">
        <svg class="w-8 h-8 text-ivy" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0" /></svg>
        <h2 class="text-lg font-bold text-heading">Peak Potential Consulting</h2>
      </div>
      <p class="text-sm text-body mb-6 flex-1">My consulting practice helping organizations build leaders, teams, and learning cultures that work across borders.</p>
      <a
        href="https://peakpotentialconsulting.com"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block text-center px-5 py-3 bg-ivy text-white font-semibold rounded-lg hover:bg-ivy-light transition-colors"
      >
        Visit Peak Potential
      </a>
    </div>
  </div>
</BaseLayout>
