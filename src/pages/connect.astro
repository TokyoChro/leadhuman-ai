    <p class="text-sm text-body mb-4 max-w-2xl">My consulting practice helping organizations build leaders, teams, and learning cultures that work across borders.</p>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4 max-w-3xl">
      <!-- Website -->
      <a
        href="https://peakpotentialconsulting.com"
        target="_blank"
        rel="noopener noreferrer"
        class="bg-surface border border-card-border rounded-lg p-5 flex flex-col items-center gap-3 hover:border-ivy transition-colors group"
      >
        <svg class="w-8 h-8 text-ivy" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" /></svg>
