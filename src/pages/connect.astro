---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Connect" description="Get in touch with Jay Vergara.">
  <h1 class="text-3xl font-bold mb-6 text-heading">Connect</h1>

  <div class="space-y-4 max-w-md">
    <a
      href="https://linkedin.com/in/vergarajay/"
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-3 px-5 py-4 bg-ivy text-white font-semibold rounded-lg hover:bg-ivy-light transition-colors"
    >
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      LinkedIn
    </a>

    <a
      href="https://peakpotentialconsulting.com"
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-3 px-5 py-4 border border-ivy text-ivy rounded-lg hover:bg-ivy hover:text-white transition-colors"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
      Peak Potential Consulting
    </a>
  </div>
</BaseLayout>
