    <script is:inline>
      function initTimeline() {
        document.querySelectorAll('.timeline-toggle').forEach(function(btn) {
          btn.addEventListener('click', function() {
            var entry = btn.closest('[data-expandable]');
            var details = entry && entry.querySelector('.timeline-details');
            if (!details) return;
            var isExpanded = details.classList.contains('expanded');
            if (isExpanded) {
              details.classList.remove('expanded');
            } else {
              details.classList.add('expanded');
              details.classList.remove('hidden');
            }
            btn.setAttribute('aria-expanded', String(!isExpanded));
            btn.textContent = !isExpanded ? '閉じる \u2191' : 'もっと見る \u2193';
          });
        });
      }
      initTimeline();
      document.addEventListener('astro:after-swap', initTimeline);
    </script>

