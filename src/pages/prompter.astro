---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Teleprompter" description="A mobile-first teleprompter with voice-controlled scrolling.">
  <Fragment slot="head">
    <style>
      /* Prompter fullscreen overlay */
      #prompter-display {
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: #111;
        color: #f0ece4;
        overflow-y: auto;
        display: none;
        -webkit-overflow-scrolling: touch;
        touch-action: manipulation;
        scroll-behavior: auto;
      }
      #prompter-display.active { display: block; }
      #prompter-display.mirrored #prompter-text { transform: scaleX(-1); }

      #prompter-text {
        max-width: 54rem;
        margin: 0 auto;
        padding: 0 1.5rem;
        line-height: 1.6;
        word-spacing: 0.05em;
      }

      /* Reading zone guides */
      #reading-zone-top {
        position: fixed;
        top: 0; left: 0; right: 0;
        height: 28%;
        background: linear-gradient(to bottom, rgba(17,17,17,0.85), transparent);
        pointer-events: none;
        z-index: 1;
      }
      #reading-zone-bottom {
        position: fixed;
        bottom: 0; left: 0; right: 0;
        height: 45%;
        background: linear-gradient(to top, rgba(17,17,17,0.85), transparent);
        pointer-events: none;
        z-index: 1;
      }
      /* Subtle reading line */
      #reading-line {
        position: fixed;
        top: 30%;
        left: 0; right: 0;
        height: 2px;
        background: rgba(29, 90, 60, 0.4);
        pointer-events: none;
        z-index: 2;
      }

      /* Word highlighting */
      .prompter-word {
        transition: color 0.15s, opacity 0.15s;
        display: inline;
      }
      .word-spoken { opacity: 0.35; }
      .word-active { color: #4ade80; }

      /* Floating control bar */
      #control-bar {
        position: fixed;
        bottom: 1.25rem;
        left: 1rem;
        right: 1rem;
        z-index: 10000;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.625rem 1rem;
        background: rgba(0,0,0,0.6);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-radius: 1rem;
        transition: opacity 0.3s;
        flex-wrap: wrap;
      }
      @media (min-width: 640px) {
        #control-bar {
          left: 50%;
          right: auto;
          transform: translateX(-50%);
          max-width: 44rem;
          flex-wrap: nowrap;
        }
      }
      #control-bar.fade-out { opacity: 0; pointer-events: none; }

      .ctrl-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 44px;
        min-height: 44px;
        padding: 0.375rem 0.625rem;
        border-radius: 0.5rem;
        color: rgba(255,255,255,0.8);
        background: transparent;
        border: none;
        cursor: pointer;
        font-size: 1.125rem;
        transition: background 0.15s, color 0.15s;
        white-space: nowrap;
        font-family: inherit;
      }
      .ctrl-btn:hover { background: rgba(255,255,255,0.1); color: #fff; }
      .ctrl-btn.active { color: #4ade80; }
      .ctrl-btn:disabled { opacity: 0.3; cursor: default; }

      .ctrl-divider {
        width: 1px;
        height: 1.5rem;
        background: rgba(255,255,255,0.15);
        flex-shrink: 0;
      }

      .speed-display {
        color: rgba(255,255,255,0.6);
        font-size: 0.75rem;
        min-width: 2rem;
        text-align: center;
      }

      /* Mic pulse */
      @keyframes mic-pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.4; }
      }
      .mic-listening { animation: mic-pulse 1.2s ease-in-out infinite; color: #4ade80 !important; }

      /* Toggle switch */
      .toggle-track {
        position: relative;
        width: 2.75rem;
        height: 1.5rem;
        background: #555;
        border-radius: 9999px;
        cursor: pointer;
        transition: background 0.2s;
        flex-shrink: 0;
      }
      .toggle-track.on { background: #1d5a3c; }
      .toggle-track .toggle-knob {
        position: absolute;
        top: 2px; left: 2px;
        width: 1.25rem;
        height: 1.25rem;
        background: #fff;
        border-radius: 50%;
        transition: transform 0.2s;
      }
      .toggle-track.on .toggle-knob { transform: translateX(1.25rem); }

      /* Editor mode styles */
      .settings-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
      }
      @media (min-width: 640px) {
        .settings-grid { grid-template-columns: 1fr 1fr; }
      }
      .setting-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.75rem 1rem;
        background: var(--color-surface);
        border-radius: 0.5rem;
        border: 1px solid var(--color-card-border);
      }
      .setting-label {
        font-weight: 500;
        color: var(--color-heading);
        font-size: 0.875rem;
      }
      .setting-controls {
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }
      .size-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2rem;
        height: 2rem;
        border-radius: 0.375rem;
        border: 1px solid var(--color-card-border);
        background: var(--color-ecru);
        color: var(--color-heading);
        cursor: pointer;
        font-size: 1rem;
        font-weight: 600;
        transition: background 0.15s;
      }
      .size-btn:hover { background: var(--color-card-border); }
      .size-value {
        min-width: 2.5rem;
        text-align: center;
        font-size: 0.875rem;
        color: var(--color-body);
      }
      .speed-range {
        width: 5rem;
        accent-color: #1d5a3c;
      }
    </style>
  </Fragment>

  <!-- Editor Mode -->
  <div id="editor-mode">
    <h1 class="text-3xl font-bold text-heading mb-2">Teleprompter</h1>
    <p class="text-muted mb-6">Paste your script below. Scroll with touch or mouse, adjust speed, or let voice-follow track your speech.</p>

    <textarea
      id="script-input"
      class="w-full rounded-lg border border-card-border bg-surface p-4 text-body font-mono text-base resize-y focus:outline-none focus:ring-2 focus:ring-ivy"
      style="min-height: 220px;"
      placeholder="Paste or type your script here..."
    ></textarea>

    <button id="load-sample" class="text-sm text-ivy hover:text-ivy-light mt-2 mb-6 transition-colors cursor-pointer">
      Load sample script
    </button>

    <div class="settings-grid mb-6">
      <div class="setting-row">
        <span class="setting-label">Scroll Speed</span>
        <div class="setting-controls">
          <button class="size-btn" id="speed-down">−</button>
          <input type="range" id="speed-range" min="1" max="10" value="3" class="speed-range">
          <button class="size-btn" id="speed-up">+</button>
          <span class="size-value" id="speed-val">3</span>
        </div>
      </div>

      <div class="setting-row">
        <span class="setting-label">Font Size</span>
        <div class="setting-controls">
          <button class="size-btn" id="font-down">−</button>
          <span class="size-value" id="font-val">36px</span>
          <button class="size-btn" id="font-up">+</button>
        </div>
      </div>

      <div class="setting-row">
        <span class="setting-label">Mirror Mode</span>
        <div class="setting-controls">
          <div class="toggle-track" id="mirror-toggle">
            <div class="toggle-knob"></div>
          </div>
        </div>
      </div>

      <div class="setting-row" id="voice-setting" style="display:none;">
        <span class="setting-label">Voice Follow</span>
        <div class="setting-controls">
          <span style="font-size:1.25rem;">🎤</span>
          <div class="toggle-track" id="voice-toggle">
            <div class="toggle-knob"></div>
          </div>
        </div>
      </div>
    </div>

    <p id="voice-compat-msg" class="text-sm text-muted mb-4" style="display:none;"></p>

    <button
      id="start-btn"
      class="w-full sm:w-auto bg-ivy text-white font-semibold rounded-lg px-8 py-4 text-lg hover:bg-ivy-light transition-colors cursor-pointer disabled:opacity-40 disabled:cursor-not-allowed"
      disabled
    >
      Start Prompter
    </button>

    <p class="text-sm text-muted mt-4">
      <strong>Keyboard shortcuts</strong> (in prompter): Space = play/pause, ↑↓ = speed, M = mirror, V = voice, Esc = exit
    </p>
  </div>

  <!-- Prompter Display (fullscreen overlay) -->
  <div id="prompter-display">
    <div id="reading-zone-top"></div>
    <div id="reading-zone-bottom"></div>
    <div id="reading-line"></div>
    <div id="prompter-text"></div>

    <div id="control-bar">
      <button class="ctrl-btn" id="cb-play" title="Play/Pause">▶</button>
      <div class="ctrl-divider"></div>
      <button class="ctrl-btn" id="cb-slower" title="Slower">−</button>
      <span class="speed-display" id="cb-speed">3</span>
      <button class="ctrl-btn" id="cb-faster" title="Faster">+</button>
      <div class="ctrl-divider"></div>
      <button class="ctrl-btn" id="cb-font-down" title="Smaller text">A↓</button>
      <button class="ctrl-btn" id="cb-font-up" title="Larger text">A↑</button>
      <div class="ctrl-divider"></div>
      <button class="ctrl-btn" id="cb-mirror" title="Mirror">⇿</button>
      <button class="ctrl-btn" id="cb-voice" title="Voice Follow" style="display:none;">🎤</button>
      <div class="ctrl-divider"></div>
      <button class="ctrl-btn" id="cb-exit" title="Exit">✕</button>
    </div>
  </div>

  <script>
    // ── State ──
    let scriptText = '';
    let words = [];
    let wordSpans = [];
    let scrollSpeed = 3;
    let fontSize = 36;
    let isPlaying = false;
    let isMirrored = false;
    let isVoiceFollow = false;
    let currentWordIndex = 0;
    let recognition = null;
    let scrollRAF = null;
    let controlBarTimer = null;
    let userScrollTimer = null;
    let userScrolling = false;
    let wakeLock = null;
    let recognitionRestarts = 0;
    let recognitionRestartWindow = 0;

    const hasSpeechAPI = !!(window.SpeechRecognition || window.webkitSpeechRecognition);

    // ── DOM refs ──
    const editorMode = document.getElementById('editor-mode');
    const scriptInput = document.getElementById('script-input');
    const startBtn = document.getElementById('start-btn');
    const loadSample = document.getElementById('load-sample');
    const speedRange = document.getElementById('speed-range');
    const speedVal = document.getElementById('speed-val');
    const fontVal = document.getElementById('font-val');
    const mirrorToggle = document.getElementById('mirror-toggle');
    const voiceToggle = document.getElementById('voice-toggle');
    const voiceSetting = document.getElementById('voice-setting');
    const voiceCompatMsg = document.getElementById('voice-compat-msg');
    const prompterDisplay = document.getElementById('prompter-display');
    const prompterText = document.getElementById('prompter-text');
    const controlBar = document.getElementById('control-bar');
    const cbPlay = document.getElementById('cb-play');
    const cbSpeed = document.getElementById('cb-speed');
    const cbVoice = document.getElementById('cb-voice');
    const cbMirror = document.getElementById('cb-mirror');

    // ── Init ──
    if (hasSpeechAPI) {
      voiceSetting.style.display = 'flex';
      cbVoice.style.display = '';
    } else {
      voiceCompatMsg.textContent = 'Voice follow requires Chrome, Edge, or Safari.';
      voiceCompatMsg.style.display = 'block';
    }

    scriptInput.addEventListener('input', () => {
      startBtn.disabled = !scriptInput.value.trim();
    });

    loadSample.addEventListener('click', () => {
      scriptInput.value = `Good evening, and welcome to tonight's broadcast. We have a lot to cover, so let's get started.

Our top story tonight comes from the world of technology, where a new breakthrough in artificial intelligence is changing the way we think about human-computer interaction.

Researchers at leading universities have developed a system that can understand and respond to natural language with unprecedented accuracy. This development has implications for healthcare, education, and countless other fields.

In other news, the city council voted unanimously to approve the new community center project. The facility will include a library, gymnasium, and outdoor spaces designed for families.

The weather forecast for tomorrow calls for partly cloudy skies with a high near seventy-two degrees. Winds will be light and variable throughout the day.

That's all for tonight. Thank you for watching, and we'll see you again tomorrow evening. Good night.`;
      startBtn.disabled = false;
    });

    // ── Speed controls ──
    function setSpeed(v) {
      scrollSpeed = Math.max(1, Math.min(10, v));
      speedRange.value = scrollSpeed;
      speedVal.textContent = scrollSpeed;
      cbSpeed.textContent = scrollSpeed;
    }
    speedRange.addEventListener('input', () => setSpeed(+speedRange.value));
    document.getElementById('speed-down').addEventListener('click', () => setSpeed(scrollSpeed - 1));
    document.getElementById('speed-up').addEventListener('click', () => setSpeed(scrollSpeed + 1));

    // ── Font size controls ──
    function setFontSize(v) {
      fontSize = Math.max(20, Math.min(80, v));
      fontVal.textContent = fontSize + 'px';
      prompterText.style.fontSize = fontSize + 'px';
    }
    document.getElementById('font-down').addEventListener('click', () => setFontSize(fontSize - 4));
    document.getElementById('font-up').addEventListener('click', () => setFontSize(fontSize + 4));

    // ── Toggles ──
    mirrorToggle.addEventListener('click', () => {
      isMirrored = !isMirrored;
      mirrorToggle.classList.toggle('on', isMirrored);
    });
    voiceToggle.addEventListener('click', () => {
      isVoiceFollow = !isVoiceFollow;
      voiceToggle.classList.toggle('on', isVoiceFollow);
    });

    // ── Start Prompter ──
    startBtn.addEventListener('click', startPrompter);

    function startPrompter() {
      scriptText = scriptInput.value.trim();
      if (!scriptText) return;

      // Build word spans
      const paragraphs = scriptText.split(/\n\s*\n/);
      prompterText.innerHTML = '';
      words = [];
      wordSpans = [];

      // Add top padding so text starts below reading zone
      const topPad = document.createElement('div');
      topPad.style.height = '50vh';
      prompterText.appendChild(topPad);

      paragraphs.forEach((para, pi) => {
        const paraWords = para.replace(/\n/g, ' ').split(/\s+/).filter(Boolean);
        const paraDiv = document.createElement('div');
        paraDiv.style.marginBottom = '1.5em';

        paraWords.forEach((w) => {
          const span = document.createElement('span');
          span.className = 'prompter-word';
          span.dataset.index = words.length;
          span.textContent = w + ' ';
          paraDiv.appendChild(span);
          words.push(w);
          wordSpans.push(span);
        });

        prompterText.appendChild(paraDiv);
      });

      // Add bottom padding so text can scroll past
      const bottomPad = document.createElement('div');
      bottomPad.style.height = '70vh';
      prompterText.appendChild(bottomPad);

      // Apply settings
      prompterText.style.fontSize = fontSize + 'px';
      prompterDisplay.classList.toggle('mirrored', isMirrored);
      currentWordIndex = 0;
      isPlaying = true;
      cbPlay.textContent = '⏸';
      userScrolling = false;

      // Show prompter
      editorMode.style.display = 'none';
      prompterDisplay.classList.add('active');

      // Try fullscreen
      tryFullscreen();

      // Wake lock
      requestWakeLock();

      // Start scrolling or voice
      if (isVoiceFollow && hasSpeechAPI) {
        startVoiceRecognition();
      }
      startScrollLoop();

      // Control bar auto-hide
      showControlBar();

      // Set up touch/mouse/keyboard handlers
      setupInputHandlers();
    }

    // ── Fullscreen ──
    function tryFullscreen() {
      const el = document.documentElement;
      const rfs = el.requestFullscreen || el.webkitRequestFullscreen || el.mozRequestFullScreen;
      if (rfs) {
        rfs.call(el).catch(() => {});
      }
    }

    function exitFullscreen() {
      const efs = document.exitFullscreen || document.webkitExitFullscreen || document.mozCancelFullScreen;
      if (efs && document.fullscreenElement) {
        efs.call(document).catch(() => {});
      }
    }

    // ── Wake Lock ──
    async function requestWakeLock() {
      try {
        if ('wakeLock' in navigator) {
          wakeLock = await navigator.wakeLock.request('screen');
        }
      } catch (e) {}
    }

    function releaseWakeLock() {
      if (wakeLock) { wakeLock.release().catch(() => {}); wakeLock = null; }
    }

    // ── Scroll Loop ──
    function startScrollLoop() {
      function tick() {
        scrollRAF = requestAnimationFrame(tick);
        if (!isPlaying || userScrolling) return;
        if (isVoiceFollow) return; // voice controls scroll position
        prompterDisplay.scrollTop += scrollSpeed * 0.5;
      }
      scrollRAF = requestAnimationFrame(tick);
    }

    function stopScrollLoop() {
      if (scrollRAF) { cancelAnimationFrame(scrollRAF); scrollRAF = null; }
    }

    // ── Voice Follow ──
    function startVoiceRecognition() {
      const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
      if (!SR) return;

      recognition = new SR();
      recognition.continuous = true;
      recognition.interimResults = true;
      recognition.lang = 'en-US';

      recognition.onresult = handleSpeechResult;
      recognition.onerror = (e) => {
        if (e.error === 'no-speech' || e.error === 'audio-capture' || e.error === 'network') {
          restartRecognition();
        }
      };
      recognition.onend = () => {
        if (isVoiceFollow && prompterDisplay.classList.contains('active')) {
          restartRecognition();
        }
      };

      try { recognition.start(); } catch (e) {}
      cbVoice.classList.add('mic-listening');
    }

    function stopVoiceRecognition() {
      if (recognition) {
        isVoiceFollow = false;
        try { recognition.stop(); } catch (e) {}
        recognition = null;
      }
      cbVoice.classList.remove('mic-listening');
    }

    function restartRecognition() {
      const now = Date.now();
      if (now - recognitionRestartWindow > 10000) {
        recognitionRestarts = 0;
        recognitionRestartWindow = now;
      }
      recognitionRestarts++;
      if (recognitionRestarts > 5) {
        cbVoice.classList.remove('mic-listening');
        return;
      }
      setTimeout(() => {
        if (isVoiceFollow && prompterDisplay.classList.contains('active')) {
          try { recognition?.start(); } catch (e) {
            // Create new instance if needed
            startVoiceRecognition();
          }
        }
      }, 500);
    }

    function normalizeWord(w) {
      return w.toLowerCase().replace(/[^a-z0-9']/g, '');
    }

    function handleSpeechResult(event) {
      // Get the latest result
      let transcript = '';
      for (let i = event.resultIndex; i < event.results.length; i++) {
        transcript += event.results[i][0].transcript;
      }

      const spokenWords = transcript.trim().split(/\s+/).map(normalizeWord).filter(Boolean);
      if (spokenWords.length === 0) return;

      // Take last 4 spoken words for matching
      const matchWords = spokenWords.slice(-4);
      const windowStart = Math.max(0, currentWordIndex - 2);
      const windowEnd = Math.min(words.length, currentWordIndex + 60);

      let bestIndex = -1;
      let bestScore = 0;

      // Slide through the script window looking for best match
      for (let i = windowStart; i <= windowEnd - matchWords.length; i++) {
        let score = 0;
        for (let j = 0; j < matchWords.length; j++) {
          const scriptWord = normalizeWord(words[i + j] || '');
          if (scriptWord === matchWords[j]) {
            score += 1;
          } else if (scriptWord.startsWith(matchWords[j]) || matchWords[j].startsWith(scriptWord)) {
            score += 0.5; // partial match
          }
        }
        if (score > bestScore) {
          bestScore = score;
          bestIndex = i + matchWords.length - 1;
        }
      }

      // Require at least 1.5 score to update (prevents noise jumps)
      if (bestScore >= 1.5 && bestIndex >= currentWordIndex - 2) {
        currentWordIndex = bestIndex;
        highlightWord(currentWordIndex);
        scrollToWord(currentWordIndex);
      }
    }

    function highlightWord(index) {
      wordSpans.forEach((span, i) => {
        span.classList.toggle('word-spoken', i < index);
        span.classList.toggle('word-active', i === index);
      });
    }

    function scrollToWord(index) {
      const span = wordSpans[index];
      if (!span) return;

      const rect = span.getBoundingClientRect();
      const targetY = prompterDisplay.scrollTop + rect.top - (window.innerHeight * 0.3);

      // Smooth scroll to the word
      prompterDisplay.scrollTo({
        top: targetY,
        behavior: 'smooth'
      });
    }

    // ── Touch / Mouse / Keyboard ──
    let touchStartY = 0;
    let touchLastY = 0;
    let touchVelocity = 0;
    let momentumRAF = null;

    function setupInputHandlers() {
      // Touch
      prompterDisplay.addEventListener('touchstart', onTouchStart, { passive: false });
      prompterDisplay.addEventListener('touchmove', onTouchMove, { passive: false });
      prompterDisplay.addEventListener('touchend', onTouchEnd, { passive: true });

      // Mouse wheel
      prompterDisplay.addEventListener('wheel', onWheel, { passive: false });

      // Keyboard
      document.addEventListener('keydown', onKeyDown);

      // Control bar show on interaction
      prompterDisplay.addEventListener('mousemove', showControlBar);
      prompterDisplay.addEventListener('touchstart', showControlBar, { passive: true });

      // Fullscreen change
      document.addEventListener('fullscreenchange', onFullscreenChange);
      document.addEventListener('webkitfullscreenchange', onFullscreenChange);
    }

    function teardownInputHandlers() {
      prompterDisplay.removeEventListener('touchstart', onTouchStart);
      prompterDisplay.removeEventListener('touchmove', onTouchMove);
      prompterDisplay.removeEventListener('touchend', onTouchEnd);
      prompterDisplay.removeEventListener('wheel', onWheel);
      document.removeEventListener('keydown', onKeyDown);
      prompterDisplay.removeEventListener('mousemove', showControlBar);
      document.removeEventListener('fullscreenchange', onFullscreenChange);
      document.removeEventListener('webkitfullscreenchange', onFullscreenChange);
    }

    function pauseAutoScrollBriefly() {
      userScrolling = true;
      clearTimeout(userScrollTimer);
      userScrollTimer = setTimeout(() => { userScrolling = false; }, 3000);
    }

    function onTouchStart(e) {
      touchStartY = e.touches[0].clientY;
      touchLastY = touchStartY;
      touchVelocity = 0;
      pauseAutoScrollBriefly();
      if (momentumRAF) cancelAnimationFrame(momentumRAF);
      showControlBar();
    }

    function onTouchMove(e) {
      const y = e.touches[0].clientY;
      const delta = touchLastY - y;
      touchVelocity = delta;
      touchLastY = y;
      prompterDisplay.scrollTop += delta;
      e.preventDefault();
    }

    function onTouchEnd() {
      // Momentum scrolling
      let velocity = touchVelocity;
      function momentum() {
        if (Math.abs(velocity) < 0.5) return;
        velocity *= 0.95;
        prompterDisplay.scrollTop += velocity;
        momentumRAF = requestAnimationFrame(momentum);
      }
      momentumRAF = requestAnimationFrame(momentum);
    }

    function onWheel(e) {
      pauseAutoScrollBriefly();
      prompterDisplay.scrollTop += e.deltaY;
      e.preventDefault();
      showControlBar();
    }

    function onKeyDown(e) {
      if (!prompterDisplay.classList.contains('active')) return;

      switch (e.code) {
        case 'Space':
          e.preventDefault();
          togglePlay();
          break;
        case 'ArrowUp':
          e.preventDefault();
          setSpeed(scrollSpeed + 1);
          break;
        case 'ArrowDown':
          e.preventDefault();
          setSpeed(scrollSpeed - 1);
          break;
        case 'Escape':
          e.preventDefault();
          exitPrompter();
          break;
        case 'KeyM':
          toggleMirror();
          break;
        case 'KeyV':
          if (hasSpeechAPI) toggleVoice();
          break;
      }
      showControlBar();
    }

    function onFullscreenChange() {
      if (!document.fullscreenElement && !document.webkitFullscreenElement) {
        // User exited fullscreen via browser — keep prompter running (it's still visible as overlay)
      }
    }

    // ── Control Actions ──
    function togglePlay() {
      isPlaying = !isPlaying;
      cbPlay.textContent = isPlaying ? '⏸' : '▶';
    }

    function toggleMirror() {
      isMirrored = !isMirrored;
      prompterDisplay.classList.toggle('mirrored', isMirrored);
      cbMirror.classList.toggle('active', isMirrored);
      mirrorToggle.classList.toggle('on', isMirrored);
    }

    function toggleVoice() {
      isVoiceFollow = !isVoiceFollow;
      voiceToggle.classList.toggle('on', isVoiceFollow);
      cbVoice.classList.toggle('active', isVoiceFollow);
      if (isVoiceFollow) {
        startVoiceRecognition();
      } else {
        stopVoiceRecognition();
        // Clear highlights
        wordSpans.forEach(s => { s.classList.remove('word-spoken', 'word-active'); });
      }
    }

    function exitPrompter() {
      stopScrollLoop();
      stopVoiceRecognition();
      teardownInputHandlers();
      exitFullscreen();
      releaseWakeLock();
      prompterDisplay.classList.remove('active');
      editorMode.style.display = '';
      isPlaying = false;
      clearTimeout(controlBarTimer);
      if (momentumRAF) cancelAnimationFrame(momentumRAF);
    }

    // ── Control Bar Auto-Hide ──
    function showControlBar() {
      controlBar.classList.remove('fade-out');
      clearTimeout(controlBarTimer);
      controlBarTimer = setTimeout(() => {
        controlBar.classList.add('fade-out');
      }, 3000);
    }

    // ── Control Bar Buttons ──
    cbPlay.addEventListener('click', () => { togglePlay(); showControlBar(); });
    document.getElementById('cb-slower').addEventListener('click', () => { setSpeed(scrollSpeed - 1); showControlBar(); });
    document.getElementById('cb-faster').addEventListener('click', () => { setSpeed(scrollSpeed + 1); showControlBar(); });
    document.getElementById('cb-font-down').addEventListener('click', () => { setFontSize(fontSize - 4); showControlBar(); });
    document.getElementById('cb-font-up').addEventListener('click', () => { setFontSize(fontSize + 4); showControlBar(); });
    cbMirror.addEventListener('click', () => { toggleMirror(); showControlBar(); });
    cbVoice.addEventListener('click', () => { toggleVoice(); showControlBar(); });
    document.getElementById('cb-exit').addEventListener('click', () => { exitPrompter(); });
  </script>
</BaseLayout>
